# Kenya Policy Pressure Index — environment configuration
# Copy this file to .env and fill in values as needed.
# All defaults work out of the box; no API keys are required.

# ── General ──────────────────────────────────────────────
USE_MOCK_DATA=false
DB_PATH=data/kppi.db
UPDATE_INTERVAL_HOURS=168

# ── ExchangeRate API (optional – free tier works without key) ─
EXCHANGERATE_API_KEY=

# ── Email notifications ───────────────────────────────────
# Set EMAIL_ENABLED=true and fill in SMTP_* to receive weekly summaries.
EMAIL_ENABLED=false
EMAIL_TO=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
# Gmail App Password (NOT your login password).
# Create one at: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=

# ── Index weights (must sum to 1.0) ──────────────────────
WEIGHT_INFLATION=0.25
WEIGHT_FX=0.20
WEIGHT_BOND=0.20
WEIGHT_MARKET_STRESS=0.15
WEIGHT_POLITICAL=0.20
